    def view_statistics(self):
        """查看统计信息"""
        all_items = self.result_table.get_children()

        if not all_items:
            messagebox.showinfo("Statistics", "No data currently")
            return

        city_stats = {}
        reseller_stats = {}
        week_stats = {}

        for item in all_items:
            values = self.result_table.item(item)['values']
            reseller = values[1]
            city = values[2]
            week = values[5]

            city_stats[city] = city_stats.get(city, 0) + 1
            reseller_stats[reseller] = reseller_stats.get(reseller, 0) + 1
            week_stats[week] = week_stats.get(week, 0) + 1

        stats_window = tk.Toplevel(self.root)
        stats_window.title("Data Statistics")
        stats_window.geometry("650x550")
        stats_window.configure(bg="#e3f2fd")

        # 标题 - 蓝色
        header_frame = tk.Frame(stats_window, bg="#1976d2", height=70)
        header_frame.pack(fill='x')
        header_frame.pack_propagate(False)

        tk.Label(header_frame, text="📈 Data Statistics",
                 font=("Microsoft YaHei UI", 15, "bold"), fg="#ffffff", bg="#1976d2").pack(pady=10)
        tk.Label(header_frame, text=f"Total Records: {len(all_items)}",
                 font=("Microsoft YaHei UI", 9), fg="#bbdefb", bg="#1976d2").pack()

        # 内容区域 - 白色背景
        content_frame = tk.Frame(stats_window, bg="#ffffff", relief=tk.FLAT, bd=0)
        content_frame.pack(fill='both', expand=True, padx=20, pady=20)

        stats_text = scrolledtext.ScrolledText(content_frame, width=70, height=25,
                                              font=("Consolas", 9), bg="#e3f2fd",
                                              fg="#0d47a1", relief=tk.FLAT, padx=15, pady=15)
        stats_text.pack(padx=10, pady=10, fill='both', expand=True)

        stats_content = f"Total Records: {len(all_items)}\n\n"

        stats_content += "📆 Week Distribution:\n"
        for week, count in sorted(week_stats.items(), key=lambda x: x[1], reverse=True):
            stats_content += f"  {week}: {count} records\n"

        stats_content += "\n🏙️ City Distribution:\n"
        for city, count in sorted(city_stats.items(), key=lambda x: x[1], reverse=True):
            stats_content += f"  {city}: {count} records\n"

        stats_content += "\n👥 Reseller Distribution (Top 10):\n"
        for reseller, count in sorted(reseller_stats.items(), key=lambda x: x[1], reverse=True)[:10]:
            stats_content += f"  {reseller}: {count} records\n"

        stats_text.insert(1.0, stats_content)
        stats_text.config(state='disabled')

        # 关闭按钮 - 蓝色
        btn_frame = tk.Frame(stats_window, bg="#e3f2fd")
        btn_frame.pack(fill='x', padx=20, pady=(0, 20))

        close_btn = tk.Button(btn_frame, text="✖️ Close",
                             command=stats_window.destroy,
                             font=("Microsoft YaHei UI", 10, "bold"), bg="#2196f3", fg="#ffffff",
                             relief=tk.FLAT, cursor="hand2", padx=30, pady=10, bd=0,
                             activebackground="#1976d2", activeforeground="#ffffff")
        close_btn.pack()
        close_btn.bind("<Enter>", lambda e: close_btn.config(bg="#1976d2"))
        close_btn.bind("<Leave>", lambda e: close_btn.config(bg="#2196f3"))

    def clear_results(self):
        """清除结果"""
        for item in self.result_table.get_children():
            self.result_table.delete(item)

        self.all_data = []
        self.status_bar.config(text="Results cleared")

