        """构建导出用 DataFrame（列顺序稳定）"""
        df = pd.DataFrame(data_rows)

        column_order = None
        if header_source_path and os.path.exists(header_source_path):
            try:
                prev_header_df = pd.read_excel(header_source_path, nrows=0)
                prev_columns = list(prev_header_df.columns)
                if prev_columns:
                    column_order = prev_columns
            except Exception:
                column_order = None

        if column_order is None:
            column_order = [
                'RTM Level 4', 'APR or APP', 'RTM#', 'Self-fund', 'Review date', 'New/Refit',
                'Status', 'Comments', 'HQ ID', 'Case No.', 'Apple ID', 'SFOID/工单编号',
                'Appoint date', 'Reseller name', 'Store name', 'City', 'City rank', 'City Tier',
                'Appointed week', 'Mall sales (RMB Bn)', 'Mall size (sqm)', 'Mall sales / sqm (RMB)',
                'Store size', 'Year 1 Traffic', 'Year 1 CPU ST/week', 'Year 1 iPod /AirPodsST/week',
                'Year 1 iPhone ST/week', 'Year 1 iPad ST/week', 'Year 1 Watch ST/week',
                'Year 1 third Party % of total revenue', 'Year 1 Apple Rev (USD)', 'Year 1 ST$ (USD)',
                'Year 1 Total Revenue (USD)', 'Total Revenue in RMB/Month', 'Year 1 gross profit (USD)',
                'Year 1 gross margin %', 'Year 1 total expenses (USD)', 'Year 1 total revised expenses (USD)',
                'Credit card cost as % of revenue', 'Year 1 BE Revenue (USD/year)',
                'Year 1 BE Revenue (RMB/month)', 'Year 1 net income (USD)', 'Year 1 net income %',
                'Year 2 CPU ST/week', 'Year 2 iPod ST/week', 'Year 2 iPhone ST/week', 'Year 2 iPad ST/week',
                'Year 2 Apple Revenue', 'Year 2 Total Revenue (USD)', 'Year 2 gross profit (USD)',
                'Year 2 gross margin %', 'Year 2 net income (USD)', 'Year 2 net income %',
                'Rent/ month excl. utilities from Reseller (LC)', 'Rent/sqm/day (LC)',
                'Rent/month excl. utilities from contract (RMB)', 'Biz plan rent / Actual rent',
                'Biz plan property cost/year incl. utilities (USD)', 'Property cost/sqm/yr',
                'Utilities as % of rent cost', 'Property cost incl. utilities as % of total rev.',
                'Total staff cost (USD)', 'Staff cost as % of revenue', 'No. of staff',
                'Avg. montly Cost/staff (LC)', 'Showroom staff as % of total staff cost',
                'SFF ($)', 'SLF ($)', 'Trafic Counter ($)',
                'ROI (Apple Branded Revenue/(SFF+SLF+Traffic Counter)', 'EBITDA', 'Payback Period',
                'Comment',
                'CY', 'Financial Risk', 'Risk Comment',
                'New/Refit', 'Review date', 'HQ Burden cost as % of revenue',
                'Filename', 'Year', 'Quarter', 'Week', 'YearQuarter', 'ProcessingTime'
            ]

        for col in column_order:
            if col in df.columns:
                continue
            match = re.match(r'^(.*)\.(\d+)$', str(col))
            if match:
                base_col = match.group(1)
                if base_col in df.columns:
                    df[col] = df[base_col]
                    continue
            df[col] = ""

        return df[column_order], column_order

    def save_results_to_file(self, output_file, data_rows=None, header_source_path=None, show_message=True):
        """保存结果到指定文件（支持自动续写场景）"""
        if data_rows is None:
            data_rows = self.all_data

        if not data_rows:
            if show_message:
                messagebox.showwarning("Warning", "No data to save, please extract data first")
            return False

        try:
            df_display, column_order = self.build_export_dataframe(data_rows, header_source_path)
            df_display.to_excel(output_file, index=False, sheet_name='Cost Tracker Data')
            self.output_file_path = output_file

            if show_message:
                success_msg = f"Data saved to:\n{output_file}\n\n"
                success_msg += f"✓ Saved {len(df_display)} records\n"
                success_msg += f"✓ Processed {self.summary_info.get('WeeksProcessed', '?')} weeks\n"
                success_msg += f"✓ Total fields: {len(column_order) - 6} data fields + 6 metadata fields\n"
                messagebox.showinfo("Save Successful", success_msg)

                if messagebox.askyesno("Open File", "Open the result file now?"):
                    try:
                        if os.name == 'nt':
                            os.startfile(output_file)
                        elif os.name == 'posix':
                            import subprocess
                            subprocess.call(['open', output_file])
                    except Exception as e:
                        messagebox.showwarning("Cannot Open", f"Cannot auto-open file: {e}")

            return True
        except Exception as e:
            if show_message:
                messagebox.showerror("Save Failed", f"Error saving file:\n{str(e)}")
            else:
                print(f"[ERROR] Auto-save failed: {str(e)}")
            import traceback
            traceback.print_exc()
            return False

    def save_results(self):
        """保存结果到Excel"""
        if not hasattr(self, 'all_data') or not self.all_data:
            messagebox.showwarning("Warning", "No data to save, please extract data first")
            return

        year = self.year_var.get()
        quarter = self.quarter_var.get()
        default_name = f"CostTracker_{year}{quarter}_Result_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"

        output_file = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")],
            initialfile=default_name
        )
        if not output_file:
            return

        header_source_path = None
        if self.new_data_file_path and os.path.exists(self.new_data_file_path):
            header_source_path = self.new_data_file_path
        elif self.previous_file_path and os.path.exists(self.previous_file_path):
            header_source_path = self.previous_file_path

        self.save_results_to_file(output_file, data_rows=self.all_data, header_source_path=header_source_path, show_message=True)

