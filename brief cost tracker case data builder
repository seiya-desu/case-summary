    def load_previous_data(self):
        """加载上一次的数据"""
        if not self.previous_file_path or not os.path.exists(self.previous_file_path):
            return None

        try:
            # 读取上一次的结果文件
            df_previous = pd.read_excel(self.previous_file_path)

            # 转换为字典列表格式以保持一致性
            previous_data = df_previous.to_dict('records')

            # 更新处理时间
            current_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            for item in previous_data:
                item['ProcessingTime'] = current_time

            self.status_bar.config(text=f"Loaded {len(previous_data)} records from previous file")
            return previous_data
        except Exception as e:
            messagebox.showwarning("Warning", f"Failed to load previous file: {str(e)}")
            return None

    def merge_data(self, new_data, previous_data):
        """合并新旧数据，去除重复"""
        if previous_data is None:
            return new_data

        # 合并数据
        merged_data = previous_data + new_data

        # 去除可能的重复记录（基于Filename）
        seen = set()
        unique_data = []

        for item in merged_data:
            key = item.get('Filename', '')
            if key not in seen:
                seen.add(key)
                unique_data.append(item)

        self.status_bar.config(
            text=f"Merged: {len(previous_data)} previous + {len(new_data)} new = {len(unique_data)} total")
        return unique_data

    def start_extraction(self):
        """开始提取数据"""
        quarter_folder_path = self.folder_path_var.get()

        if not quarter_folder_path or not os.path.exists(quarter_folder_path):
            messagebox.showwarning("Warning", "Please select a valid quarter folder path")
            return

        # 检查必需的文件
        if not self.city_ranking_file_path or not os.path.exists(self.city_ranking_file_path):
            messagebox.showwarning("Warning", "Please select City Ranking file")
            return

        if not self.reseller_list_file_path or not os.path.exists(self.reseller_list_file_path):
            messagebox.showwarning("Warning", "Please select Reseller List file")
            return

        year = self.year_var.get()
        quarter = self.quarter_var.get()

        if not year or not quarter:
            messagebox.showwarning("Warning", "Please enter year and quarter information")
            return

        self.clear_results()

        # 创建 extractor 实例，传入文件路径
        self.extractor = CostTrackerExtractor(
            city_ranking_path=self.city_ranking_file_path,
            reseller_list_path=self.reseller_list_file_path
        )

        # 检查是否有上一次结果文件
        previous_data = None
        if self.previous_file_path:
            self.status_bar.config(text=f"Loading previous data and extracting quarter {year}{quarter}...")
            previous_data = self.load_previous_data()
        else:
            self.status_bar.config(text=f"Extracting quarter {year}{quarter}...")

        self.root.update()

        try:
            # 使用季度文件夹处理方法
            all_data, summary_info = self.extractor.batch_process_quarter_folder(quarter_folder_path, year, quarter)

            if not all_data:
                messagebox.showinfo("Info", "No data extracted")
                self.status_bar.config(text="Extraction completed, no data")
                return

            # 如果有上一次数据，合并
            if previous_data is not None:
                all_data = self.merge_data(all_data, previous_data)

            self.display_results(all_data)
            self.all_data = all_data
            self.summary_info = summary_info

            self.display_summary_info(summary_info)

            # 更新状态栏信息
            if previous_data is not None:
                self.status_bar.config(
