class CostTrackerExtractor:
    def __init__(self, city_ranking_path=None, reseller_list_path=None):
        # Store type keywords
        self.city_ranking_df = None
        self.reseller_list_df = None
        self.city_ranking_path = city_ranking_path
        self.reseller_list_path = reseller_list_path
        self.load_lookup_files()

    def load_lookup_files(self):
        """辅助文件"""
        try:
            if self.city_ranking_path and os.path.exists(self.city_ranking_path):
                self.city_ranking_df = pd.read_excel(self.city_ranking_path)
                print(f"[OK] Loaded city ranking file: {len(self.city_ranking_df)} records")
            else:
                print(f"[Warning] City ranking file not found or not specified")

            if self.reseller_list_path and os.path.exists(self.reseller_list_path):
                self.reseller_list_df = pd.read_excel(self.reseller_list_path)
                print(f"[OK] Loaded reseller list file: {len(self.reseller_list_df)} records")
            else:
                print(f"[Warning] Reseller list file not found or not specified")

        except Exception as e:
            print(f"[Warning] Error loading lookup files: {str(e)}")
            import traceback
            traceback.print_exc()

    def vlookup_city_rank(self, city_name):
        """City Rank"""
        if self.city_ranking_df is None or city_name is None or city_name == "":
            return "Unknown"

        try:
            city_name_clean = str(city_name).strip().lower()

            df = self.city_ranking_df.iloc[1:]

            result = None
            for idx, row in df.iterrows():
                city_f = str(row.iloc[5]).strip().lower()  # F列
                if city_f == city_name_clean:
                    result = row.iloc[7]  # H列
                    break

            if result is None or result == 0 or result == "":
                for idx, row in df.iterrows():
                    city_m = str(row.iloc[12]).strip().lower()  # M列
                    if city_m == city_name_clean:
                        result = row.iloc[13]  # N列
                        break

            if result is None or result == "" or result == 0:
                print(f"[Warning] City rank not found for: '{city_name}'")
                return "Unknown"

            print(f"[OK] City rank found for '{city_name}': {result}")
            return result

        except Exception as e:
            print(f"[ERROR] Error in vlookup_city_rank for '{city_name}': {str(e)}")
            import traceback
            traceback.print_exc()
            return "Unknown"

    def vlookup_rtm_level4(self, hq_id):
        """RTM Level 4 -HQ ID"""
        if self.reseller_list_df is None or hq_id is None or hq_id == "":
            return ""

        try:
            hq_id_clean = str(hq_id).strip()

            # A列是 Reseller HQ ID，G列是 RTM
            hq_id_col = self.reseller_list_df.columns[0]  
            rtm_col = self.reseller_list_df.columns[6]     

            for idx, row in self.reseller_list_df.iterrows():
                df_hq_id = str(row[hq_id_col]).strip()
                if df_hq_id == hq_id_clean:
                    rtm_value = row[rtm_col]
                    print(f"[OK] RTM Level 4 found for HQ ID '{hq_id_clean}': '{rtm_value}'")
                    return rtm_value

            print(f"[Warning] RTM Level 4 not found for HQ ID: '{hq_id_clean}'")
            return ""

        except Exception as e:
            print(f"[ERROR] Error in vlookup_rtm_level4 for HQ ID '{hq_id}': {str(e)}")
            import traceback
            traceback.print_exc()
            return ""

    def extract_case_no_from_filename(self, folder_name):
        """从文件夹名称中提取Case No，例如 '9) 266187 Sunion...' 提取 '9'"""
        try:
            # 匹配开头的数字，后面可能跟着 ')' 或空格
            match = re.match(r'^(\d+)', folder_name)
            if match:
                case_no = match.group(1)
                print(f"[DEBUG] Extracted Case No: '{case_no}' from folder: '{folder_name}'")
                return case_no
            print(f"[DEBUG] Case No not found in folder: '{folder_name}'")
            return ""
        except Exception as e:
            print(f"[ERROR] Error extracting case no: {str(e)}")
            return ""

    def extract_sfoid_from_filename(self, folder_name):
        """从文件夹名称中提取SFOID，例如 '...(FY260010740)' 提取 'FY260010740'"""
        try:
            match = re.search(r'\((FY\d+)\)$', folder_name)
            if match:
                sfoid = match.group(1)
                print(f"[DEBUG] Extracted SFOID: '{sfoid}' from folder: '{folder_name}'")
                return sfoid

            match = re.search(r'\(([^)]+)\)$', folder_name)
            if match:
                sfoid = match.group(1)
                print(f"[DEBUG] Extracted SFOID (generic): '{sfoid}' from folder: '{folder_name}'")
                return sfoid

            print(f"[DEBUG] SFOID not found in folder: '{folder_name}'")
            return ""
        except Exception as e:
            print(f"[ERROR] Error extracting SFOID: {str(e)}")
            return ""

    def safe_read_cell(self, sheet, cell_ref, default=0):
        """读取单元格值"""
        try:
            value = sheet[cell_ref].value
            if value is None:
                return default
            # 如果是数字类型，直接返回
            if isinstance(value, (int, float)):
                return value
            # 如果是字符串，尝试转换为数字
            if isinstance(value, str):
                # 移除逗号和空格
                cleaned = value.replace(',', '').replace(' ', '').strip()
                if cleaned == '' or cleaned == '-':
                    return default
                try:
                    return float(cleaned)
                except:
                    return value
            return value
        except Exception as e:
            print(f"Error reading cell {cell_ref}: {str(e)}")
            return default

    def safe_divide(self, numerator, denominator, default=0):
        """安全除法"""
        try:
            if denominator == 0 or denominator is None:
                return default
            return numerator / denominator
        except:
            return default

    def extract_review_date_from_week_folder(self, file_path):
        """从周文件夹名称提取日期，例如 W1-20251230 -> 30-Dec-25"""
        try:
            week_folder = os.path.basename(os.path.dirname(os.path.dirname(file_path)))

            # 支持 W1-20251230 / W1_20251230 / W1 20251230 等格式
            match = re.search(r'W\d{1,2}[-_\s]?(\d{8})', week_folder, re.IGNORECASE)
            if match:
                dt = datetime.strptime(match.group(1), '%Y%m%d')
                review_date = dt.strftime('%d-%b-%y')
                print(f"[DEBUG] Review date extracted from week folder '{week_folder}': {review_date}")
                return review_date

            # 兜底：若周文件夹里有任意连续8位日期，也尝试解析
            generic_match = re.search(r'(\d{8})', week_folder)
            if generic_match:
                dt = datetime.strptime(generic_match.group(1), '%Y%m%d')
                review_date = dt.strftime('%d-%b-%y')
                print(f"[DEBUG] Review date extracted from generic date in '{week_folder}': {review_date}")
                return review_date

        except Exception as e:
            print(f"[Warning] Failed to parse review date from week folder: {str(e)}")

        fallback = datetime.now().strftime('%d-%b-%y')
        print(f"[Warning] Week folder date not found, fallback to current date: {fallback}")
        return fallback

    def _format_review_date(self, raw_value):
        """将不同类型的日期值统一格式化为 DD-Mon-YY，失败返回空字符串"""
        if raw_value is None:
            return ""

        # datetime/date 直接格式化
        if isinstance(raw_value, datetime):
            return raw_value.strftime('%d-%b-%y')
        if isinstance(raw_value, date):
            return datetime(raw_value.year, raw_value.month, raw_value.day).strftime('%d-%b-%y')

        # Excel serial date (兼容被读成数字的情况)
        if isinstance(raw_value, (int, float)):
            if 20000 <= float(raw_value) <= 60000:
                try:
                    dt = datetime(1899, 12, 30) + timedelta(days=float(raw_value))
                    return dt.strftime('%d-%b-%y')
                except Exception:
                    return ""
            return ""

        if isinstance(raw_value, str):
            text = raw_value.strip()
            if not text:
                return ""

            # 常见日期格式兜底
            date_formats = [
                '%d-%b-%y', '%d-%b-%Y', '%d/%m/%Y', '%d/%m/%y', '%Y-%m-%d', '%Y/%m/%d',
                '%m/%d/%Y', '%m/%d/%y', '%d.%m.%Y', '%d.%m.%y', '%d %b %Y', '%d %b %y'
            ]
            for fmt in date_formats:
                try:
                    return datetime.strptime(text, fmt).strftime('%d-%b-%y')
                except ValueError:
                    continue

            # 字符串里带时间时尝试截断
            short_text = text.split(' ')[0]
            for fmt in ['%Y-%m-%d', '%Y/%m/%d', '%d/%m/%Y', '%m/%d/%Y']:
                try:
                    return datetime.strptime(short_text, fmt).strftime('%d-%b-%y')
                except ValueError:
                    continue

        return ""

    def extract_review_date(self, ws_input):
        """优先读取 E13/E14/J13/J14，再扫描 E/J 列，找不到返回 0"""
        # 1) 先按固定候选格查找（13/14 行）
        primary_cells = ['E13', 'E14', 'J13', 'J14']
        for cell_ref in primary_cells:
            raw = ws_input[cell_ref].value
            parsed = self._format_review_date(raw)
            if parsed:
                print(f"[DEBUG] Review date found at {cell_ref}: {parsed}")
                return parsed

        # 2) 扫描 E/J 整列
        max_row = ws_input.max_row if ws_input.max_row and ws_input.max_row > 0 else 200
        for col in ['E', 'J']:
            for r in range(1, max_row + 1):
                parsed = self._format_review_date(ws_input[f'{col}{r}'].value)
                if parsed:
                    print(f"[DEBUG] Review date found in column {col}{r}: {parsed}")
                    return parsed

        # 3) 最后兜底
        fallback = datetime.now().strftime('%d-%b-%y')
        print(f"[Warning] Review date not found in E/J target cells, fallback to current date: {fallback}")
        return fallback

    def process_single_file(self, file_path, year=None, quarter=None, week=None):
        """
        提取50个字段的数据
        """
        try:
            filename = os.path.basename(file_path)

            # 获取父文件夹名称
            parent_folder = os.path.basename(os.path.dirname(file_path))
            print(f"[DEBUG] Processing file: {filename}")
            print(f"[DEBUG] Parent folder: {parent_folder}")

            # 打开Excel文件
            wb = load_workbook(file_path, data_only=True, read_only=False)

            # 检查必需的sheet是否存在
            input_sheet_name = 'input'
            pnl_usd_sheet_name = 'Partner P&L ($USD)'
            pnl_local_sheet_name = 'Partner P&L (Local Currency)'

            # 查找input sheet（不区分大小写）
            if input_sheet_name not in wb.sheetnames:
                for name in wb.sheetnames:
                    if name.lower() == 'input':
                        input_sheet_name = name
                        break
                else:
                    wb.close()
                    return False, [], f"Input sheet not found"

            ws_input = wb[input_sheet_name]

            # 查找P&L sheets
            ws_pnl_usd = None
            ws_pnl_local = None

            for name in wb.sheetnames:
                if 'partner p&l' in name.lower() and 'usd' in name.lower():
                    ws_pnl_usd = wb[name]
                elif 'partner p&l' in name.lower() and 'local' in name.lower():
                    ws_pnl_local = wb[name]

            data_row = {}

            # 1. RTM Level 4 - 使用HQ ID查找
            hq_id = self.safe_read_cell(ws_input, 'D14', "")
            data_row['RTM Level 4'] = self.vlookup_rtm_level4(hq_id)

            # 2. APR or APP
            data_row['APR or APP'] = self.safe_read_cell(ws_input, 'M26', "")

            # 3. RTM#
            data_row['RTM#'] = ""

            # 4. Self-fund
            data_row['Self-fund'] = ""

            # 5. Review date - 从周文件夹名称提取日期（如 W1-20251230）
            data_row['Review date'] = self.extract_review_date_from_week_folder(file_path)

            # 6. New/Refit
            data_row['New/Refit'] = self.safe_read_cell(ws_input, 'I22', "")

            # 7. Status
            data_row['Status'] = "WW approved"

            # 8. Comments
            data_row['Comments'] = ""

            # 9. HQ ID
            data_row['HQ ID'] = hq_id  

            # 10. Case No. - 从父文件夹名称提取
            data_row['Case No.'] = self.extract_case_no_from_filename(parent_folder)

            # 11. Apple ID 
            apple_id = self.safe_read_cell(ws_input, 'D17', "")

            # 如果D17为空，尝试读取周围单元格作为fallback
            if not apple_id or str(apple_id).strip() == "":
                print(f"[DEBUG] Apple ID at D17 is empty for file: {filename}")
                print(f"[DEBUG] Trying fallback cells...")

                # 尝试读取D16, D18, E17作为fallback
                fallback_cells = ['D16', 'D18', 'E17']
                for cell_ref in fallback_cells:
                    fallback_value = self.safe_read_cell(ws_input, cell_ref, "")
                    if fallback_value and str(fallback_value).strip() != "":
                        print(f"[DEBUG] Found Apple ID in fallback cell {cell_ref}: '{fallback_value}'")
                        apple_id = fallback_value
                        break

                if not apple_id or str(apple_id).strip() == "":
                    print(f"[DEBUG] Apple ID not found in D17 or fallback cells")

                    d17_cell = ws_input['D17']
                    print(f"[DEBUG] D17 cell details - value: {d17_cell.value}, data_type: {d17_cell.data_type}")
            else:
                print(f"[DEBUG] Apple ID found at D17: '{apple_id}'")

            data_row['Apple ID'] = apple_id

            # 12. SFOID/工单编号 
            data_row['SFOID/工单编号'] = self.extract_sfoid_from_filename(parent_folder)
            
            # 13. Appoint date
            data_row['Appoint date'] = ""

            # 14. Reseller name
            reseller_name = self.safe_read_cell(ws_input, 'D13', "")
            data_row['Reseller name'] = reseller_name
            
            # 15. Store name
            data_row['Store name'] = self.safe_read_cell(ws_input, 'I23', "")
            
            # 16. City (处理合并单元格 D24:E24)
            city_value = ws_input['D24'].value
            if city_value is None:
                # 尝试从合并单元格读取
                for merge_range in ws_input.merged_cells.ranges:
                    if (merge_range.min_row == 24 and merge_range.max_row == 24 and
                            merge_range.min_col == 4 and merge_range.max_col == 5):
                        city_value = ws_input.cell(row=merge_range.min_row, column=merge_range.min_col).value
                        break
            data_row['City'] = str(city_value).strip() if city_value is not None else ""
            
            # 17. City rank
            data_row['City rank'] = self.vlookup_city_rank(data_row['City'])
            
            # 18. City Tier
            data_row['City Tier'] = ""
            
            # 19. Appointed week
            data_row['Appointed week'] = ""
            
            # 20. Mall sales (RMB Bn)
            q23_value = self.safe_read_cell(ws_input, 'Q23', 0)
            data_row['Mall sales (RMB Bn)'] = self.safe_divide(q23_value, 1000000000, 0)
            
            # 21. Mall size (sqm)
            data_row['Mall size (sqm)'] = self.safe_read_cell(ws_input, 'Q25', 0)
            
            # 22. Mall sales / sqm (RMB)
            i26_value = self.safe_read_cell(ws_input, 'I26', 0)
            data_row['Mall sales / sqm (RMB)'] = self.safe_divide(q23_value, i26_value, 0)
            
            # 23. Store size
            data_row['Store size'] = i26_value
            
            # 24. Year 1 Traffic
            data_row['Year 1 Traffic'] = self.safe_read_cell(ws_input, 'M22', 0)
            
            # 25. Year 1 CPU ST/week
            data_row['Year 1 CPU ST/week'] = self.safe_read_cell(ws_input, 'V52', 0)
            
            # 26. Year 1 iPod /AirPodsST/week
            data_row['Year 1 iPod /AirPodsST/week'] = self.safe_read_cell(ws_input, 'V55', 0)
            
            # 27. Year 1 iPhone ST/week
            data_row['Year 1 iPhone ST/week'] = self.safe_read_cell(ws_input, 'V51', 0)
            
            # 28. Year 1 iPad ST/week
            data_row['Year 1 iPad ST/week'] = self.safe_read_cell(ws_input, 'V53', 0)
            
            # 29. Year 1 Watch ST/week
            data_row['Year 1 Watch ST/week'] = self.safe_read_cell(ws_input, 'V54', 0)
            
            # 30. Year 1 third Party % of total revenue
            data_row['Year 1 third Party % of total revenue'] = self.safe_read_cell(ws_input, 'R61', 0)
            
            # 31-38: 从 Partner P&L ($USD) sheet 读取
            if ws_pnl_usd:
                # 31. Year 1 Apple Rev (USD)
                data_row['Year 1 Apple Rev (USD)'] = self.safe_read_cell(ws_pnl_usd, 'C10', 0)
                
                # 32. Year 1 ST$ (USD) = C9 + C24 - C69
                c9 = self.safe_read_cell(ws_pnl_usd, 'C9', 0)
                c24 = self.safe_read_cell(ws_pnl_usd, 'C24', 0)
                c69 = self.safe_read_cell(ws_pnl_usd, 'C69', 0)
                data_row['Year 1 ST$ (USD)'] = c9 + c24 - c69
                
                # 33. Year 1 Total Revenue (USD)
                data_row['Year 1 Total Revenue (USD)'] = c9
                
                # 35. Year 1 gross profit (USD)
                data_row['Year 1 gross profit (USD)'] = c69
                
                # 36. Year 1 gross margin %
                data_row['Year 1 gross margin %'] = self.safe_read_cell(ws_pnl_usd, 'H69', 0)
                
                # 37. Year 1 total expenses (USD) - 取负数
                c70 = self.safe_read_cell(ws_pnl_usd, 'C70', 0)
                data_row['Year 1 total expenses (USD)'] = c70 * -1

                # 38. Year 1 total revised expenses (USD) - 需要先读取 Rent/month contract RMB
                # 公式: =IF(BD="", AK, AK+(BD-BB)*12/7.172)
                # BD = Rent/month contract RMB (Input!M48)
                # BB = Rent/month Reseller LC (已在后面计算)
                # AK = Year 1 total expenses (USD)
                rent_contract_rmb = self.safe_read_cell(ws_input, 'M48', 0)  # BD
                # 注意：BB 需要在这里提前计算
                n48_value = self.safe_read_cell(ws_input, 'N48', 0)
                rent_reseller_lc = self.safe_divide(n48_value, 12, 0)  # BB

                # 应用公式
                if rent_contract_rmb == 0 or rent_contract_rmb == "":
                    data_row['Year 1 total revised expenses (USD)'] = data_row['Year 1 total expenses (USD)']
                else:
                    adjustment = (rent_contract_rmb - rent_reseller_lc) * 12 / 7.172
                    data_row['Year 1 total revised expenses (USD)'] = data_row['Year 1 total expenses (USD)'] + adjustment
                
                # 48. EBITDA
                data_row['EBITDA'] = self.safe_read_cell(ws_pnl_usd, 'H88', 0)
            else:
                data_row['Year 1 Apple Rev (USD)'] = 0
                data_row['Year 1 ST$ (USD)'] = 0
                data_row['Year 1 Total Revenue (USD)'] = 0
                data_row['Year 1 gross profit (USD)'] = 0
                data_row['Year 1 gross margin %'] = 0
                data_row['Year 1 total expenses (USD)'] = 0
                data_row['Year 1 total revised expenses (USD)'] = 0
                data_row['EBITDA'] = 0
            
            # 34. Total Revenue in RMB/Month
            if ws_pnl_local:
                c9_local = self.safe_read_cell(ws_pnl_local, 'C9', 0)
                data_row['Total Revenue in RMB/Month'] = self.safe_divide(c9_local, 12, 0)
            else:
                data_row['Total Revenue in RMB/Month'] = 0
            
            # 39. Credit card cost as % of revenue
            data_row['Credit card cost as % of revenue'] = self.safe_read_cell(ws_input, 'M80', 0)
            
            # 40. Year 1 BE Revenue (USD/year)
            data_row['Year 1 BE Revenue (USD/year)'] = self.safe_read_cell(ws_input, 'M53', 0)

            # 41. Year 1 BE Revenue (RMB/month) - 新增字段
            be_revenue_usd = data_row['Year 1 BE Revenue (USD/year)']
            # 假设汇率为7（可根据实际情况调整）
            data_row['Year 1 BE Revenue (RMB/month)'] = self.safe_divide(be_revenue_usd * 7, 12, 0)

            # 42. Year 1 net income (USD) - 新增字段
            # net income = gross profit - total expenses
            gross_profit = data_row.get('Year 1 gross profit (USD)', 0)
            total_expenses = data_row.get('Year 1 total expenses (USD)', 0)
            data_row['Year 1 net income (USD)'] = gross_profit - total_expenses

            # 43. Year 1 net income % - 新增字段
            total_revenue = data_row.get('Year 1 Total Revenue (USD)', 0)
            net_income = data_row['Year 1 net income (USD)']
            data_row['Year 1 net income %'] = self.safe_divide(net_income, total_revenue, 0)

            # 44-48: Year 2 数据
            # 44. Year 2 CPU ST/week
            data_row['Year 2 CPU ST/week'] = self.safe_read_cell(ws_input, 'W52', 0)

            # 45. Year 2 iPod ST/week
            data_row['Year 2 iPod ST/week'] = self.safe_read_cell(ws_input, 'W55', 0)

            # 46. Year 2 iPhone ST/week
            data_row['Year 2 iPhone ST/week'] = self.safe_read_cell(ws_input, 'W51', 0)

            # 47. Year 2 iPad ST/week
            data_row['Year 2 iPad ST/week'] = self.safe_read_cell(ws_input, 'W53', 0)

            # 48-52: Year 2 Revenue and Profit (从 Partner P&L ($USD) sheet)
            if ws_pnl_usd:
                # 48. Year 2 Apple Revenue
                data_row['Year 2 Apple Revenue'] = self.safe_read_cell(ws_pnl_usd, 'D10', 0)

                # 49. Year 2 Total Revenue (USD)
                data_row['Year 2 Total Revenue (USD)'] = self.safe_read_cell(ws_pnl_usd, 'D9', 0)

                # 50. Year 2 gross profit (USD)
                data_row['Year 2 gross profit (USD)'] = self.safe_read_cell(ws_pnl_usd, 'D69', 0)

                # 51. Year 2 gross margin %
                data_row['Year 2 gross margin %'] = self.safe_read_cell(ws_pnl_usd, 'H69', 0)

                # 52. Year 2 net income (USD)
                year2_gross_profit = data_row['Year 2 gross profit (USD)']
                year2_total_expenses = self.safe_read_cell(ws_pnl_usd, 'D70', 0) * -1
                data_row['Year 2 net income (USD)'] = year2_gross_profit - year2_total_expenses

                # 53. Year 2 net income %
                year2_total_revenue = data_row['Year 2 Total Revenue (USD)']
                data_row['Year 2 net income %'] = self.safe_divide(data_row['Year 2 net income (USD)'], year2_total_revenue, 0)
            else:
                data_row['Year 2 Apple Revenue'] = 0
                data_row['Year 2 Total Revenue (USD)'] = 0
                data_row['Year 2 gross profit (USD)'] = 0
                data_row['Year 2 gross margin %'] = 0
                data_row['Year 2 net income (USD)'] = 0
                data_row['Year 2 net income %'] = 0

            # 54. Rent/ month excl. utilities from Reseller (LC)
            n48_value = self.safe_read_cell(ws_input, 'N48', 0)
            data_row['Rent/ month excl. utilities from Reseller (LC)'] = self.safe_divide(n48_value, 12, 0)

            # 55. Rent/sqm/day (LC)
            rent_per_month = data_row['Rent/ month excl. utilities from Reseller (LC)']
            store_size = data_row.get('Store size', 0)
            data_row['Rent/sqm/day (LC)'] = self.safe_divide(rent_per_month, (store_size * 30), 0)

            # 56. Rent/month excl. utilities from contract (RMB)
            data_row['Rent/month excl. utilities from contract (RMB)'] = self.safe_read_cell(ws_input, 'M48', 0)

            # 57. Biz plan rent / Actual rent
            rent_contract_rmb = data_row['Rent/month excl. utilities from contract (RMB)']
            rent_reseller_lc = data_row['Rent/ month excl. utilities from Reseller (LC)']
            exchange_rate = self.safe_read_cell(ws_input, 'P8', 7.172)
            if exchange_rate == 0:
                exchange_rate = 7.172
            # 将 Reseller LC 转换为 RMB 进行比较
            rent_reseller_rmb = rent_reseller_lc * exchange_rate
            data_row['Biz plan rent / Actual rent'] = self.safe_divide(rent_contract_rmb, rent_reseller_rmb, 0)

            # 58. Biz plan property cost/year incl. utilities (USD)
            data_row['Biz plan property cost/year incl. utilities (USD)'] = self.safe_read_cell(ws_input, 'M53', 0)

            # 59. Property cost/sqm/yr
            property_cost_year = data_row['Biz plan property cost/year incl. utilities (USD)']
            data_row['Property cost/sqm/yr'] = self.safe_divide(property_cost_year, store_size, 0)

            # 60. Utilities as % of rent cost
            # 公式: =(BF4167-BB4167*12/$P$8)/BF4167
            # BF = Biz plan property cost/year incl. utilities (USD)
            # BB = Rent/month Reseller LC
            # $P$8 = 汇率 (通常从 Input!P8 读取，如果为空则使用 7.172)
            exchange_rate = self.safe_read_cell(ws_input, 'P8', 7.172)
            if exchange_rate == 0:
                exchange_rate = 7.172  # 默认汇率

            property_cost_year = data_row['Biz plan property cost/year incl. utilities (USD)']
            rent_month_lc = data_row['Rent/ month excl. utilities from Reseller (LC)']

            if property_cost_year != 0:
                utilities_cost = property_cost_year - (rent_month_lc * 12 / exchange_rate)
                data_row['Utilities as % of rent cost'] = self.safe_divide(utilities_cost, property_cost_year, 0)
            else:
                data_row['Utilities as % of rent cost'] = 0

            # 61. Property cost incl. utilities as % of total rev.
            data_row['Property cost incl. utilities as % of total rev.'] = self.safe_divide(property_cost_year, total_revenue, 0)

            # 62. Total staff cost (USD)
            data_row['Total staff cost (USD)'] = self.safe_read_cell(ws_input, 'M68', 0)

            # 63. Staff cost as % of revenue
            staff_cost = data_row['Total staff cost (USD)']
            data_row['Staff cost as % of revenue'] = self.safe_divide(staff_cost, total_revenue, 0)

            # 64. No. of staff
            m65 = self.safe_read_cell(ws_input, 'M65', 0)
            m66 = self.safe_read_cell(ws_input, 'M66', 0)
            m67 = self.safe_read_cell(ws_input, 'M67', 0)
            data_row['No. of staff'] = m65 + m66 + m67

            # 65. Avg. montly Cost/staff (LC)
            num_staff = data_row['No. of staff']
            data_row['Avg. montly Cost/staff (LC)'] = self.safe_divide(staff_cost * exchange_rate / 12, num_staff, 0) if num_staff > 0 else 0

            # 66. Showroom staff as % of total staff cost
            data_row['Showroom staff as % of total staff cost'] = "100%"

            # 67. SFF ($)
            sff = self.safe_read_cell(ws_input, 'D56', 0)
            data_row['SFF ($)'] = sff

            # 68. SLF ($)
            slf = self.safe_read_cell(ws_input, 'D57', 0)
            data_row['SLF ($)'] = slf

            # 69. Trafic Counter ($)
            traffic_counter = self.safe_read_cell(ws_input, 'D58', 0)
            data_row['Trafic Counter ($)'] = traffic_counter

            # 70. ROI (Apple Branded Revenue/(SFF+SLF+Traffic Counter))
            apple_rev = data_row['Year 1 Apple Rev (USD)']
            total_investment = sff + slf + traffic_counter
            data_row['ROI (Apple Branded Revenue/(SFF+SLF+Traffic Counter)'] = self.safe_divide(apple_rev, total_investment, 0)

            # 71. EBITDA (已在前面设置)
            # data_row['EBITDA'] 已经设置

            # 72. Payback Period
            annual_net_income = data_row['Year 1 net income (USD)']
            data_row['Payback Period'] = self.safe_divide(total_investment, annual_net_income, 0) if annual_net_income > 0 else 0

            # 73. Comment
            data_row['Comment'] = ""

            # 74-75. 空列 (保留两个空列)

            # 76. CY (当前年份)
            data_row['CY'] = datetime.now().year

            # 77. Financial Risk
            data_row['Financial Risk'] = ""

            # 78. Risk Comment
            data_row['Risk Comment'] = ""

            # 79. New/Refit (重复字段，已在前面设置)
            # 80. Review date (重复字段，已在前面设置)

            # 81. HQ Burden cost as % of revenue
            data_row['HQ Burden cost as % of revenue'] = self.safe_read_cell(ws_input, 'M79', 0)
            
            # 添加元数据
            data_row['Filename'] = filename
            data_row['Year'] = year if year else "Not specified"
            data_row['Quarter'] = quarter if quarter else "Not specified"
            data_row['Week'] = week if week else "Not specified"
            data_row['YearQuarter'] = f"{year}{quarter}" if year and quarter else "Not specified"
            data_row['ProcessingTime'] = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            
            wb.close()
            
            return True, [data_row], "Successfully processed"
            
        except Exception as e:
            return False, [], f"Error processing file: {str(e)}"

    def batch_process_week_folder(self, folder_path, year=None, quarter=None, week=None):
        """批量处理特定周文件夹中的所有Excel文件"""
        if not os.path.exists(folder_path):
            return [], f"Week folder does not exist: {folder_path}"
        
        excel_extensions = ['.xlsx', '.xls', '.xlsm']
        excel_files = []
        
        print(f"Start searching week folder: {folder_path}")
        
        # 搜索Excel文件
        for root, dirs, files in os.walk(folder_path):
            print(f"Searching directory: {root}")
            print(f"Number of files in directory: {len(files)}")
            
            for file in files:
                file_extension = os.path.splitext(file)[1].lower()
                filename_upper = file.upper()
                
                # 检查是否以APR或APP开头且是Excel文件
                if (filename_upper.startswith('APR') and file_extension in excel_extensions) or (
                        filename_upper.startswith('APP') and file_extension in excel_extensions):
                    full_path = os.path.join(root, file)
                    excel_files.append(full_path)
                    print(f"Found APR/APP file: {full_path}")
                elif file_extension in excel_extensions:
                    full_path = os.path.join(root, file)
                    print(f"Found non-APR Excel file: {full_path}")
        
        # 如果没有找到APR文件，尝试搜索所有Excel文件
        if not excel_files:
            print("No APR Excel files found, trying to search all Excel files...")
            for root, dirs, files in os.walk(folder_path):
                for file in files:
                    file_extension = os.path.splitext(file)[1].lower()
                    if file_extension in excel_extensions:
                        full_path = os.path.join(root, file)
                        excel_files.append(full_path)
                        print(f"Found file: {full_path}")
        
        if not excel_files:
            return [], f"No Excel files found in week folder"
        
        print(f"Found {len(excel_files)} Excel files in week {week}")
        
        # 处理每个文件
        all_data = []
        success_count = 0
        fail_count = 0
        failed_files = []
        
        for file_path in excel_files:
            print(f"Processing: {os.path.basename(file_path)}")
            success, data, message = self.process_single_file(file_path, year, quarter, week)
            
            if success:
                all_data.extend(data)
                success_count += 1
                print(f"  ✓ Success: {message}")
            else:
                fail_count += 1
                failed_files.append((os.path.basename(file_path), message))
                print(f"  ✗ Failed: {message}")
        
        return all_data, success_count, fail_count, failed_files, len(excel_files)

    def batch_process_quarter_folder(self, quarter_folder_path, year=None, quarter=None):
        """批量处理包含周子文件夹（W1, W2, ..., W13）的季度文件夹"""
        if not os.path.exists(quarter_folder_path):
            return [], f"Quarter folder does not exist: {quarter_folder_path}"
        
        print(f"Start processing quarter folder: {quarter_folder_path}")
        
        # 查找所有周文件夹（W开头，后面跟着数字1-13）
        week_folders = []
        for item in os.listdir(quarter_folder_path):
            item_path = os.path.join(quarter_folder_path, item)
            if os.path.isdir(item_path):
                week_match = re.match(r'^W(\d{1,2})', item, re.IGNORECASE)
                if week_match:
                    week_num = int(week_match.group(1))
                    if 1 <= week_num <= 13:
                        week_folders.append((item_path, week_num, item))
                        print(f"Found week folder: {item} (Week {week_num})")
        
        if not week_folders:
            return [], f"No week folders (starting with W1, W2, ..., W13) found in quarter folder"
        
        # 按周数排序
        week_folders.sort(key=lambda x: x[1])
        
        print(f"Found {len(week_folders)} week folders")
        
        # 处理每个周文件夹
        all_data = []
        total_excel_files = 0
        total_success = 0
        total_fail = 0
        all_failed_files = []
        week_stats = []
        
        for week_folder_path, week_num, folder_name in week_folders:
            week_str = f"Week {week_num}"
            print(f"\n{'=' * 50}")
            print(f"Processing {week_str} ({folder_name})...")
            print(f"{'=' * 50}")
            
            week_data, success_count, fail_count, failed_files, excel_count = self.batch_process_week_folder(
                week_folder_path, year, quarter, week_str
            )
            
            # 添加周数据到总数据
            all_data.extend(week_data)
            
            # 更新统计
            total_excel_files += excel_count
            total_success += success_count
            total_fail += fail_count
            all_failed_files.extend(failed_files)
            
            week_stats.append({
                'Week': week_str,
                'Folder': folder_name,
                'ExcelFiles': excel_count,
                'SuccessFiles': success_count,
                'FailedFiles': fail_count,
                'Records': len(week_data)
            })
            
            print(f"{week_str} ({folder_name}) completed: {success_count}/{excel_count} files successful, {len(week_data)} records")
        
        # 统计信息
        summary_info = {
            'TotalFiles': total_excel_files,
            'SuccessFiles': total_success,
            'FailedFiles': total_fail,
            'TotalRecords': len(all_data),
            'FailedFileList': all_failed_files,
            'Year': year,
            'Quarter': quarter,
            'WeekStats': week_stats,
            'SearchFolder': quarter_folder_path,
            'WeeksProcessed': len(week_folders)
        }
        
        return all_data, summary_info


